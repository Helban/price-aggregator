ALLEGRO_CLIENT_ID=your_client_id_here
ALLEGRO_CLIENT_SECRET=your_client_secret_here

# Google Cloud Vision API key — enables image search in the web UI.
# Setup: console.cloud.google.com -> new project -> enable "Cloud Vision API"
#        -> Credentials -> create API key (restrict to Vision API) -> enable billing.
# Billing must be enabled, but the first 1000 images/month are free.
GOOGLE_VISION_API_KEY=your_key_here
